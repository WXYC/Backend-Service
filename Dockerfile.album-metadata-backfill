#Build stage
FROM node:24-alpine AS builder

WORKDIR /album-metadata-backfill-builder

COPY ./package.json ./package-lock.json ./
COPY ./tsconfig.base.json ./
COPY ./shared/database ./shared/database
COPY ./jobs/album-metadata-backfill ./jobs/album-metadata-backfill

RUN npm ci && npm run build --workspace=@wxyc/database --workspace=@wxyc/album-metadata-backfill

#Production stage
FROM node:24-alpine AS prod

WORKDIR /album-metadata-backfill

COPY ./package* ./
COPY ./jobs/album-metadata-backfill/package* ./jobs/album-metadata-backfill/
COPY ./shared/database/package* ./shared/database/

RUN npm install --omit=dev

COPY --from=builder ./album-metadata-backfill-builder/jobs/album-metadata-backfill/dist ./jobs/album-metadata-backfill/dist
COPY --from=builder ./album-metadata-backfill-builder/shared/database/dist ./shared/database/dist

CMD ["npm", "start", "--workspace=@wxyc/album-metadata-backfill"]
