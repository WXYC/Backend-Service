{
  "name": "@wxyc/rotation-dedupe",
  "job-type": "one-shot",
  "version": "1.0.0",
  "description": "WXYC one-shot dedupe: collapse duplicate active rotation rows for the same (album_id, rotation_bin) by killing all but the most recent (#694).",
  "type": "module",
  "main": "./dist/job.js",
  "scripts": {
    "start": "node dist/job.js",
    "build": "tsup --minify",
    "clean": "rm -rf dist",
    "docker:build": "docker build -t wxyc_rotation_dedupe:ci -f ../../Dockerfile.rotation-dedupe ../../",
    "dev": "tsup --watch"
  },
  "license": "MIT",
  "dependencies": {
    "@sentry/node": "^10.50.0",
    "@wxyc/database": "^1.0.0"
  },
  "peerDependencies": {
    "drizzle-orm": "^0.45.0"
  },
  "devDependencies": {
    "typescript": "^6.0.3"
  }
}
