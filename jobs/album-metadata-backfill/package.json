{
  "name": "@wxyc/album-metadata-backfill",
  "job-type": "one-shot",
  "version": "1.0.0",
  "description": "WXYC one-shot historical backfill: populate album_metadata from the enriched subset of flowsheet (Epic D / BS#898).",
  "type": "module",
  "main": "./dist/job.js",
  "scripts": {
    "start": "node dist/job.js",
    "build": "tsup --minify",
    "clean": "rm -rf dist",
    "docker:build": "docker build -t wxyc_album_metadata_backfill:ci -f ../../Dockerfile.album-metadata-backfill ../../",
    "dev": "tsup --watch"
  },
  "license": "MIT",
  "dependencies": {
    "@wxyc/database": "^1.0.0"
  },
  "peerDependencies": {
    "drizzle-orm": "^0.45.0"
  },
  "devDependencies": {
    "typescript": "^6.0.3"
  }
}
