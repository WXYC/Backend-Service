#Build stage
FROM node:24-alpine AS builder

WORKDIR /artist-search-alias-consumer-builder

COPY ./package.json ./package-lock.json ./
COPY ./tsconfig.base.json ./
COPY ./shared/database ./shared/database
COPY ./jobs/artist-search-alias-consumer ./jobs/artist-search-alias-consumer

RUN npm ci && npm run build --workspace=@wxyc/database --workspace=@wxyc/artist-search-alias-consumer

#Production stage
FROM node:24-alpine AS prod

WORKDIR /artist-search-alias-consumer

ENV DB_STATEMENT_TIMEOUT_MS=60000
ENV DB_APPLICATION_NAME=wxyc-artist-search-alias-consumer

COPY ./package* ./
COPY ./jobs/artist-search-alias-consumer/package* ./jobs/artist-search-alias-consumer/
COPY ./shared/database/package* ./shared/database/

RUN npm install --omit=dev

COPY --from=builder ./artist-search-alias-consumer-builder/jobs/artist-search-alias-consumer/dist ./jobs/artist-search-alias-consumer/dist
COPY --from=builder ./artist-search-alias-consumer-builder/shared/database/dist ./shared/database/dist

CMD ["npm", "start", "--workspace=@wxyc/artist-search-alias-consumer"]
