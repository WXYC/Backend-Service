{
  "name": "@wxyc/auth-service",
  "publishPort": "8082",
  "version": "1.0.0",
  "description": "WXYC Authentication Service using Better Auth",
  "type": "module",
  "main": "./dist/app.js",
  "scripts": {
    "start": "node --import ./dist/instrument.js dist/app.js",
    "build": "tsup --minify",
    "clean": "rm -rf dist",
    "docker:build": "docker build --build-arg NPM_TOKEN=$NPM_TOKEN -t wxyc_auth_service:ci -f ../../Dockerfile.auth ../../",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "author": "Jackson Meade",
  "license": "MIT",
  "dependencies": {
    "@sentry/node": "^10.63.0",
    "@wxyc/authentication": "^1.0.0",
    "@wxyc/database": "^1.0.0",
    "@wxyc/shared": "^1.12.0",
    "better-auth": "^1.6.23",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2"
  },
  "peerDependencies": {
    "drizzle-orm": "^0.45.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/express-serve-static-core": "^5.1.1",
    "typescript": "^6.0.3"
  }
}
