{
  "name": "@wxyc/backend",
  "publishPort": "8080",
  "version": "1.0.0",
  "description": "An API service for the flowsheet database of WXYC",
  "type": "module",
  "main": "./dist/app.js",
  "scripts": {
    "start": "node --import ./dist/instrument.js dist/app.js",
    "build": "tsup --minify",
    "clean": "rm -rf dist",
    "docker:build": "docker build --build-arg NPM_TOKEN=$NPM_TOKEN -t wxyc_backend_service:ci -f ../../Dockerfile.backend ../../",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "author": "AyBruno",
  "license": "MIT",
  "dependencies": {
    "@aws-sdk/client-cloudwatch": "^3.1045.0",
    "@sentry/node": "^10.52.0",
    "@tensorflow/tfjs": "^4.22.0",
    "@wxyc/authentication": "^1.0.0",
    "@wxyc/database": "^1.0.0",
    "@wxyc/lml-client": "^1.0.0",
    "@wxyc/shared": "^1.6.0",
    "async-mutex": "^0.5.0",
    "aws-jwt-verify": "^5.1.1",
    "axios": "^1.16.0",
    "better-auth": "^1.6.9",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.1",
    "groq-sdk": "^1.1.2",
    "jose": "^6.2.3",
    "lru-cache": "^11.3.6",
    "node-fetch": "^3.3.2",
    "node-ssh": "^13.2.1",
    "nsfwjs": "^4.3.0",
    "postgres": "^3.4.9",
    "posthog-node": "^5.33.4",
    "sharp": "^0.34.5",
    "ssh2": "^1.17.0",
    "swagger-ui-express": "^5.0.1",
    "ws": "^8.20.0",
    "yaml": "^2.8.4"
  },
  "peerDependencies": {
    "drizzle-orm": "^0.45.0"
  }
}
