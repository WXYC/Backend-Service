{
  "name": "@wxyc/enrichment-worker",
  "version": "1.0.0",
  "description": "WXYC enrichment worker: CDC-driven consumer that enriches flowsheet track rows with LML metadata. Replaces the in-BS fire-and-forget enrichment pattern with an N×N idempotent-claim worker (Epic C C2 / BS#892).",
  "type": "module",
  "main": "./dist/worker.js",
  "publishPort": "8084",
  "scripts": {
    "start": "node --import ./dist/instrument.js dist/worker.js",
    "build": "tsup --minify",
    "clean": "rm -rf dist",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "license": "MIT",
  "dependencies": {
    "@sentry/node": "^10.59.0",
    "@wxyc/database": "^1.0.0",
    "@wxyc/lml-client": "^1.0.0",
    "@wxyc/metadata": "^1.0.0",
    "dotenv": "^17.4.2"
  },
  "peerDependencies": {
    "drizzle-orm": "^0.45.0"
  },
  "devDependencies": {
    "typescript": "^7.0.2"
  }
}
