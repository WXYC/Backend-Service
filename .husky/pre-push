# Skip validation if every ref being pushed is a deletion. Git signals a
# delete by sending an all-zero `local_sha` (40 chars for SHA-1, 64 for
# SHA-256); the `*[!0]*` glob matches any string containing a non-zero
# character, so the case fires only for real pushes. Running typecheck/
# lint on a delete-only push wastes ~80s and can OOM the hook.
has_real_push=false
while read local_ref local_sha remote_ref remote_sha; do
  case "$local_sha" in
    *[!0]*) has_real_push=true; break ;;
  esac
done

if [ "$has_real_push" = false ]; then
  exit 0
fi

# NOTE: keep each check on its own line. Husky runs this script under
# `sh -e`, and POSIX errexit does NOT abort on failures inside an AND-OR
# list (e.g. `npm run typecheck && npm run lint`) — the shell exempts
# commands whose exit status is "used by a command that uses its result",
# which includes both sides of `&&`. So chaining these with `&&` silently
# lets a typecheck failure fall through to the next line. One command per
# line, no `&&`, so `set -e` actually fires.
npm run typecheck
npm run lint
# `check:docs` is the warn-only pair (doc-budget + doc-rules): they surface
# gentle nudges about markdown hygiene but shouldn't block a push.
npm run check:docs || true
# `check:auth-tables-doc` (BS#1573) is hard-fail — it enforces the
# CLAUDE.md sentinel list against the Drizzle schema, and a mismatch is
# always a bug. Kept separate so `|| true` above doesn't mask it.
npm run check:auth-tables-doc
