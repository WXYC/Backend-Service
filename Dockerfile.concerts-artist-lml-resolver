#Build stage
FROM node:24-alpine AS builder

ARG NPM_TOKEN
WORKDIR /concerts-artist-lml-resolver-builder

COPY ./.npmrc ./
COPY ./package.json ./package-lock.json ./
COPY ./tsconfig.base.json ./
COPY ./shared/database ./shared/database
COPY ./shared/lml-client ./shared/lml-client
# The clean-name gate (`isCleanHeadliner`) is imported RELATIVELY from
# jobs/triangle-shows-etl/headliner.ts — the BS#1614 constraint that the gate
# and the extraction rules live in one module. tsup bundles it into dist at
# build time, so the source tree must be present here (but not in prod).
COPY ./jobs/triangle-shows-etl ./jobs/triangle-shows-etl
COPY ./jobs/concerts-artist-lml-resolver ./jobs/concerts-artist-lml-resolver

RUN npm ci && npm run build --workspace=@wxyc/database --workspace=@wxyc/lml-client --workspace=@wxyc/concerts-artist-lml-resolver

#Production stage
FROM node:24-alpine AS prod

ARG NPM_TOKEN
WORKDIR /concerts-artist-lml-resolver

COPY ./.npmrc ./
COPY ./package* ./
COPY ./jobs/concerts-artist-lml-resolver/package* ./jobs/concerts-artist-lml-resolver/
COPY ./shared/database/package* ./shared/database/
COPY ./shared/lml-client/package* ./shared/lml-client/

# `@wxyc/lml-client` declares `@wxyc/shared` as a registry dependency
# (GitHub Packages, `@wxyc:registry` in `.npmrc`). Without NPM_TOKEN +
# .npmrc the prod stage's npm install 401s on @wxyc/shared. Mirrors the
# pattern in Dockerfile.catalog-popularity-freetext-resolve.
RUN npm install --omit=dev && rm -f .npmrc

COPY --from=builder ./concerts-artist-lml-resolver-builder/jobs/concerts-artist-lml-resolver/dist ./jobs/concerts-artist-lml-resolver/dist
COPY --from=builder ./concerts-artist-lml-resolver-builder/shared/database/dist ./shared/database/dist
COPY --from=builder ./concerts-artist-lml-resolver-builder/shared/lml-client/dist ./shared/lml-client/dist

# Identifies the connection in pg_stat_activity during incident triage.
ENV DB_APPLICATION_NAME=wxyc-concerts-artist-lml-resolver

# ENTRYPOINT + empty CMD so docker-level args (e.g. `--dry-run`) pass through
# to the job rather than replacing the launcher. ENTRYPOINT pins the launcher;
# any args after `<image>` extend it. node resolves `@wxyc/database` etc. via
# the standard walk up to /concerts-artist-lml-resolver/node_modules.
ENTRYPOINT ["node", "/concerts-artist-lml-resolver/jobs/concerts-artist-lml-resolver/dist/job.js"]
CMD []
